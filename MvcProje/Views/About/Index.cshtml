@using EntityLayer.Concrate
@model List<About>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Hakkımızda Verileri</h2>
<table class="table table-bordered">
    <tr>
        <th>ID</th>
        <th>Başlık</th>
        <th>Kurtar</th>
        <th>Sil</th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.AboutID</td>
            <td>@item.AboutDetails1</td>
            <td><a href="#" class="btn btn-success">Kurtar</a></td>
            <td><a href="#" class="btn btn-danger">Sil</a></td>
            
        </tr>
        }

    </table>



    <button class="btn btn-info" data-toggle="modal" data-target="#Modal1">Veri Girişi</button>

    <div class="modal" id="Modal1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title">Yeni Veri Girişi</h3>
                </div>
                <form method="post" action="/About/AddAbout/">
                    <div class="modal-body">
                        <label>Hakkımda Metin 1</label>
                        <input type="text" name="AboutDetails1" class="form-control" />
                        <br />
                        <label>Hakkımda Metin 2</label>
                        <input type="text" name="AboutDetails2" class="form-control" />
                        <br />
                        <label>Hakkımda Görsel 1</label>
                        <input type="text" name="AboutImage1" class="form-control" />
                        <br />
                        <label>Hakkımda Görsel 2</label>
                        <input type="text" name="AboutImage2" class="form-control" />
                        <br />
                        <button class="btn btn-success">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>