@model EntityLayer.Concrate.Heading
@{
    ViewBag.Title = "EditHeading";
    Layout = "~/Views/Shared/_WriterLayout.cshtml";
}


<h2>Başlık Güncelleme Sayfası </h2>
<br />
@using (Html.BeginForm("EditHeading", "WriterPanel", FormMethod.Post))

{
    <div>
        @Html.HiddenFor(x => x.HeadingID)

       
        @Html.HiddenFor(x => x.HeadingDate)
       
       
        @Html.HiddenFor(x => x.WriterID)
        
        @Html.Label("Başlık Adı")
        @Html.TextAreaFor(x => x.HeadingName, new { @class = "form-control" })
        <br />
        @Html.Label("Kategori")
        @Html.DropDownListFor(x => x.CategoryID, (List<SelectListItem>)ViewBag.vlc, new { @class = "form-control" })
    </div>
    <br />
    <button class="btn btn-success">Güncelle</button>
}




