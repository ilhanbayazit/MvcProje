@model EntityLayer.Concrate.Category
@{
    Layout = null;
}
<link href="~/Content/bootstrap.min.css" rel="stylesheet" />

<h1>Kategori Ekleme Sayfası</h1>
<br />

@using (Html.BeginForm("AddCategory", "Category", FormMethod.Post))
{

<div class="form-group"> 
  @Html.Label("Kategori Adı")
  @Html.TextAreaFor(x => x.CategoryName)
  @Html.ValidationMessageFor(x=>x.CategoryName)
  <br /> <br />
  @Html.Label("Kategori Açıklaması")
  @Html.TextAreaFor(x => x.CategoryDescription)
  @Html.ValidationMessageFor(x=>x.CategoryDescription)
  <br /> <br />
  <button>Kaydet</button>
</div>


}


